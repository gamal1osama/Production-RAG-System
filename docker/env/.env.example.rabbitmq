# RabbitMQ Configuration Example
RABBIT_DEFAULT_USER=ragsys_user
RABBIT_DEFAULT_PASS=ragsys_rabbitmq_password
RABBIT_DEFAULT_VHOST=ragsys_vhost

# Management Plugin
RABBITMQ_MANAGEMENT_ENABLED=true

# Security
RABBITMQ_AUTH_BACKENDS=rabbit_auth_backend_internal

# Performance
RABBITMQ_DISK_FREE_LIMIT=2000000000
